<?xml version="1.0" encoding="utf-8"?>
<!--
    Anotether explicitly disables all cloud and device backups.
    Session keys and ephemeral state must NEVER be backed up to Google Drive
    or transferred to another device. Sessions are ephemeral by design.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
